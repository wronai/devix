# devix Environment Variables

# Windsurf/Claude API
WINDSURF_API_KEY=your-api-key-here
WINDSURF_API_URL=http://localhost:8080/api

# GUI Automation
DISPLAY=:0

# Project Settings
PROJECT_PATH=..
MAX_ITERATIONS=50
AUTO_CONTINUE=true

# Thresholds
TEST_COVERAGE_THRESHOLD=80
CODE_QUALITY_THRESHOLD=8.0
PERFORMANCE_THRESHOLD=1000

# Logging
LOG_LEVEL=INFO
